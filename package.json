{
  "name": "solid-editor-core",
  "type": "module",
  "version": "1.0.0",
  "private": false,
  "description": "A simple unstyled editor based on SolidJS and CodeMirror6",
  "homepage": "https://github.com/g-mero/solid-editor-core",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "solid": "./dist/index.jsx",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "solid": "./dist/*/index.jsx",
      "default": "./dist/*/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {},
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsup --dts",
    "pub": "pnpm build && pnpm publish"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.3",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/state": "^6.4.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.34.3",
    "@lezer/highlight": "^1.2.1",
    "codemirror": "^6.0.1",
    "solid-uses": "^0.6.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.9.2",
    "@iconify-json/ri": "^1.2.3",
    "@lezer/markdown": "^1.3.2",
    "@types/node": "^22.9.1",
    "@unocss/reset": "^0.64.1",
    "@unocss/vite": "^0.64.1",
    "esbuild-plugin-solid": "^0.6.0",
    "eslint": "^9.15.0",
    "eslint-plugin-solid": "^0.14.4",
    "jige-core": "^0.15.0",
    "jige-ui": "^0.15.4",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "unocss": "^0.64.1",
    "vite": "^5.4.11",
    "vite-plugin-solid": "^2.10.2"
  }
}
